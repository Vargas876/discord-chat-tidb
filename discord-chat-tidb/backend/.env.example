# ============================================
# CONFIGURACIÓN DE BASE DE DATOS TiDB CLOUD
# ============================================

# URL de conexión a TiDB Cloud
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE?sslaccept=strict
# 
# Para obtener estos datos:
# 1. Ve a https://tidbcloud.com
# 2. Selecciona tu cluster → Click "Connect"
# 3. Copia los parámetros y reemplaza abajo

DATABASE_URL="mysql://username:password@gateway-xx.aws.tidbcloud.com:4000/database?sslaccept=strict"

# Puerto del servidor WebSocket
WS_PORT=3002

# Puerto del backend Next.js
PORT=3001
